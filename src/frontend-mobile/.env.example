# Copie para .env:  cp .env.example .env  (Expo só lê .env, não .env.example)
# Firebase: use EXPO_PUBLIC_* (recomendado). NEXT_PUBLIC_* do web também funciona (fallback no código).

EXPO_PUBLIC_API_URL=http://192.168.0.10:3030

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In: Web Client ID (Firebase → Google → Configuração SDK Web).
# No Google Cloud → Credenciais → OAuth Web → URIs de redirecionamento, adicione as URIs
# que o app imprime no console ao abrir /login (ex.: http://localhost:8081, unitechfrota://oauthredirect).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Dev: evita inicializar o Firebase (ex.: auth/invalid-api-key). Login/senha entram direto na UI.
EXPO_PUBLIC_SKIP_FIREBASE_AUTH=
# Alias de SKIP_FIREBASE_AUTH
EXPO_PUBLIC_FIREBASE_DISABLE=
# JWT do Firebase para chamadas à API quando SKIP_FIREBASE_AUTH=1
EXPO_PUBLIC_DEV_ID_TOKEN=
# Se a chave não começar com AIza mas for válida, use 1 para não desativar o Firebase automaticamente
EXPO_PUBLIC_FIREBASE_CONFIG_OK=
