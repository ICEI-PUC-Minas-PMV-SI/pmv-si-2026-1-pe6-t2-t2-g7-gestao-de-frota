  "components": {
    "securitySchemes": {
      "ID_TOKEN": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "in": "header"
      }
    },
    "schemas": {
      "UpdateUserRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          }
        },
        "required": [
          "name"
        ]
      },
      "GetUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "uid": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "example": "johndoe@email.com"
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "provider": {
            "type": "string",
            "example": "google"
          },
          "role": {
            "type": "string",
            "example": "admin"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2025-10-04T21:08:42.332Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2025-10-04T21:08:42.332Z"
          }
        },
        "required": [
          "id",
          "uid",
          "email",
          "name",
          "provider",
          "role",
          "createdAt",
          "updatedAt"
        ]
      },
      "ListMembersResponseDto": {
        "type": "object",
        "properties": {
          "list": {
            "$ref": "#/components/schemas/GetUserResponseDto"
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "list",
          "total"
        ]
      },
      "CreateVehicleRequestDto": {
        "type": "object",
        "properties": {
          "marca": {
            "type": "string",
            "example": "Fiat"
          },
          "modelo": {
            "type": "string",
            "example": "Uno"
          },
          "ano": {
            "type": "number",
            "example": 2020
          },
          "placa": {
            "type": "string",
            "example": "ABC1D23",
            "description": "Placa no padrão Mercosul"
          }
        },
        "required": [
          "marca",
          "modelo",
          "ano",
          "placa"
        ]
      },
      "GetVehicleResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "marca": {
            "type": "string",
            "example": "Fiat"
          },
          "modelo": {
            "type": "string",
            "example": "Uno"
          },
          "ano": {
            "type": "number",
            "example": 2020
          },
          "placa": {
            "type": "string",
            "example": "ABC1D23"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2025-10-04T21:08:42.332Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2025-10-04T21:08:42.332Z"
          }
        },
        "required": [
          "id",
          "marca",
          "modelo",
          "ano",
          "placa",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateVehicleRequestDto": {
        "type": "object",
        "properties": {
          "marca": {
            "type": "string",
            "example": "Fiat"
          },
          "modelo": {
            "type": "string",
            "example": "Uno"
          },
          "ano": {
            "type": "number",
            "example": 2020
          },
          "placa": {
            "type": "string",
            "example": "ABC1D23",
            "description": "Placa no padrão Mercosul"
          }
        },
        "required": [
          "marca",
          "modelo",
          "ano",
          "placa"
        ]
      },
      "JourneyParadaRequestDto": {
        "type": "object",
