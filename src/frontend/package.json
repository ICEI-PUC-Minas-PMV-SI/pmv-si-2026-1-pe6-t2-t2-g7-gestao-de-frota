{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint --fix",
    "prettier": "prettier --write",
    "pre-commit": "lint-staged --allow-empty"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "src/**/*.+(js|jsx|ts|tsx|md|mdx)": [
      "pnpm prettier",
      "pnpm lint:fix"
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "commitizen": "^4.3.1",
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4",
    "lint-staged": "^16.4.0",
    "next": "16.2.1",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
