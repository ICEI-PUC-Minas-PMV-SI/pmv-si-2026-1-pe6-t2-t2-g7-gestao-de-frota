{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint --fix",
    "prettier": "prettier --write",
    "pre-commit": "lint-staged --allow-empty",
    "cy:open": "cypress open",
    "cy:run": "cypress run"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "src/**/*.+(js|jsx|ts|tsx|md|mdx)": [
      "pnpm prettier",
      "pnpm lint:fix"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "axios": "1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commitizen": "^4.3.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.11.0",
    "input-otp": "^1.4.2",
    "leaflet": "^1.9.4",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "prettier": "^3.8.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
